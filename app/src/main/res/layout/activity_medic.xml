<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B5E20"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/headerMedic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="PANOU TRIAJ"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sistem de Monitorizare în Timp Real"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabContainer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_below="@id/headerMedic"
        android:layout_marginBottom="16dp"
        android:background="#26000000"
        android:padding="4dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabSpital"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:text="🏥 ÎN SPITAL"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabAsteptare"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:text="🚑 ÎN PROCESARE"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="#26000000"
            app:cornerRadius="8dp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tabContainer"
        android:layout_above="@+id/btnLogOutMedic">

        <LinearLayout
            android:id="@+id/layoutInSpital"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <ListView
                android:id="@+id/lvPacientiInSpital"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="#40FFFFFF"
                android:dividerHeight="8dp"
                android:scrollbars="none"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutInProcesare"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <ListView
                android:id="@+id/lvAlerteNoi"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="#40FFFFFF"
                android:dividerHeight="8dp"
                android:scrollbars="none"/>
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogOutMedic"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:text="IEȘIRE DIN SISTEM"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:backgroundTint="#66000000"
        app:cornerRadius="12dp"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="2dp" />

</RelativeLayout>