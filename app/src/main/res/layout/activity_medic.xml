<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMedicWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Panou Triaj Medic"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvMedicSpecialty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Specialitate"
            android:textColor="#1976D2"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lista pacienților este ordonată de AI în funcție de prioritate."
            android:textColor="#555555"
            android:layout_marginBottom="24dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPacient1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFF0F0"
                android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔴 COD ROȘU - TIMP: ACUM" android:textStyle="bold" android:textColor="#D32F2F" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pacient: Ion Popescu (54 ani)" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Repartizare: Parter, Sala 1 (Resuscitare)" android:textColor="#424242" android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Click pentru a vedea dosarul complet..." android:textColor="#1976D2" android:textStyle="italic" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPacient2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFDE7"
                android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🟡 COD GALBEN - Așteptare: 15 min" android:textStyle="bold" android:textColor="#FBC02D" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pacient: Maria Ionescu (32 ani)" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Repartizare: Etajul 1, Sala 4 (Chirurgie Minoră)" android:textColor="#424242" android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Click pentru a vedea dosarul complet..." android:textColor="#1976D2" android:textStyle="italic" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPacient3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F1F8E9"
                android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🟢 COD VERDE - Așteptare: 45 min" android:textStyle="bold" android:textColor="#388E3C" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pacient: Andrei Vasile (21 ani)" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Repartizare: Etajul 2, Sala 10 (Consultații)" android:textColor="#424242" android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Click pentru a vedea dosarul complet..." android:textColor="#1976D2" android:textStyle="italic" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

        <Button
            android:id="@+id/btnLogOutMedic"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Log Out"
            android:backgroundTint="#757575"/>

    </LinearLayout>
</ScrollView>