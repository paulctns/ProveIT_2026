<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scanare Buletin"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <ImageView
        android:id="@+id/ivPreviewBuletin"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:background="#DDDDDD"
        android:scaleType="centerInside"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnDeschideCamera"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Fă poză la buletin" />

    <Button
        android:id="@+id/btnTrimiteCatreAI"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Analizează buletinul"
        android:visibility="gone"
        android:backgroundTint="#4CAF50" />

    <ProgressBar
        android:id="@+id/progressBarAI"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvStatusAI"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Se procesează..."
        android:visibility="gone"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvRezultatScanare"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Datele vor apărea aici..."
        android:textSize="16sp"
        android:textColor="#333333"
        android:padding="12dp"
        android:background="#F0F0F0" />

</LinearLayout>