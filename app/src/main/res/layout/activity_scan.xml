<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scanare Buletin"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Asigură-te că datele (CNP, Seria) sunt vizibile și clare."
        android:textAlignment="center"
        android:textColor="#555555"
        android:layout_marginBottom="32dp"/>

    <ImageView
        android:id="@+id/ivPreviewBuletin"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:background="#E0E0E0"
        android:scaleType="centerCrop"
        android:layout_marginBottom="32dp"/>

    <ProgressBar
        android:id="@+id/progressBarAI"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvStatusAI"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Se analizează datele cu Gemini AI..."
        android:textColor="#2196F3"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnDeschideCamera"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="📷 Deschide Camera"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnTrimiteCatreAI"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Analizează Buletinul"
        android:backgroundTint="#4CAF50"
        android:textSize="18sp"
        android:visibility="gone"/>

</LinearLayout>