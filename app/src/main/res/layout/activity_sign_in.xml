<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B5E20">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-black"
                android:text="CREARE CONT NOU"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center" />

            <RadioGroup
                android:id="@+id/rgTipUtilizator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp">
                <RadioButton android:id="@+id/rbPacient" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SUNT PACIENT" android:textColor="#FFFFFF" android:textStyle="bold" android:buttonTint="#FFFFFF" android:checked="true"/>
                <RadioButton android:id="@+id/rbMedic" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SUNT MEDIC" android:textColor="#FFFFFF" android:textStyle="bold" android:buttonTint="#FFFFFF"/>
            </RadioGroup>

            <EditText android:id="@+id/etEmail" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Email" android:textColorHint="#555555" android:background="@android:drawable/editbox_background" android:backgroundTint="#F5F5F5" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="8dp" android:elevation="4dp"/>
            <EditText android:id="@+id/etPassword" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Parolă" android:inputType="textPassword" android:textColorHint="#555555" android:background="@android:drawable/editbox_background" android:backgroundTint="#F5F5F5" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="16dp" android:elevation="4dp"/>

            <LinearLayout
                android:id="@+id/layoutDateMedicale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="DATE MEDICALE" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <EditText android:id="@+id/etCNP" android:layout_width="match_parent" android:layout_height="55dp" android:hint="CNP" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etVarsta" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Vârstă" android:inputType="number" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etGrupaSange" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Grupa Sânge" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etAlergii" android:layout_width="match_parent" android:layout_height="80dp" android:hint="Alergii" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="8dp" android:gravity="top"/>
                <EditText android:id="@+id/etBoli" android:layout_width="match_parent" android:layout_height="80dp" android:hint="Boli Cronice" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="8dp" android:gravity="top"/>
                <EditText android:id="@+id/etMedicamente" android:layout_width="match_parent" android:layout_height="80dp" android:hint="Medicamente actuale" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="16dp" android:gravity="top"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutDateMedic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="DATE PROFESIONALE" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <EditText android:id="@+id/etCodParafa" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Cod Parafă" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etEmailInstitutional" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Email Instituțional" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etIDInstitutional" android:layout_width="match_parent" android:layout_height="55dp" android:hint="ID Legitimație" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etUnitateMedicala" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Unitate Medicală" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etDepartament" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Departament" android:textColorHint="#555555" android:backgroundTint="#F5F5F5" android:background="@android:drawable/editbox_background" android:padding="12dp" android:textColor="#1B5E20" android:textStyle="bold" android:layout_marginBottom="16dp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitSignIn"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="CREEAZĂ CONT"
                android:textColor="#1B5E20"
                android:textStyle="bold"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="16dp"
                android:layout_marginBottom="40dp"/>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>